<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ── Red Toolbar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/red_primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/white"
            android:padding="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_white"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/search"
                android:tint="#AAAAAA" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Search Product"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <ImageView android:layout_width="30dp" android:layout_height="30dp"
            android:src="@drawable/baseline_photo_camera_24" android:tint="@color/white"
            android:padding="4dp" android:layout_marginEnd="4dp" />
        <ImageView android:layout_width="30dp" android:layout_height="30dp"
            android:src="@drawable/baseline_notifications_none_24" android:tint="@color/white"
            android:padding="4dp" android:layout_marginEnd="4dp" />
        <ImageView android:layout_width="30dp" android:layout_height="30dp"
            android:src="@drawable/ic_cart" android:tint="@color/white" android:padding="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="12dp">

            <!-- ── Deliver To Row ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/white"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deliver to : Indiraa shop , 641899"
                        android:textColor="#1A1A1A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18, Abirami nagar , Mayiladuthurai"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_change"
                    android:layout_width="70dp"
                    android:layout_height="32dp"
                    android:text="Change"
                    android:textColor="@color/red_primary"
                    android:textSize="11sp"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_outline_red" />
            </LinearLayout>

            <!-- ── Subtotal ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/white"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Subtotal"
                    android:textColor="#888888"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_subtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹4,995"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Payment Option Card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                android:backgroundTint="@color/white"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Option"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose how you'd like to secure your order."
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Pay 20% Now option -->
                    <LinearLayout
                        android:id="@+id/option_20"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/payment_option_selected_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_radio_selected"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pay 20% Now"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Flexible/ Popular"
                                android:textColor="#E41D27"
                                android:textSize="10sp"
                                android:background="@drawable/badge_light_red"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Payable Today"
                                    android:textColor="#888888"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tv_pay20_today"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹999"
                                    android:textColor="#1A1A1A"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Balance Later"
                                    android:textColor="#888888"
                                    android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tv_pay20_balance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹3,996"
                                    android:textColor="#1A1A1A"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Pay Full Amount option -->
                    <LinearLayout
                        android:id="@+id/option_full"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/payment_option_bg"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iv_radio_full"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_radio_unselected"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pay Full Amount"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Faster Processing"
                                android:textColor="#1AA365"
                                android:textSize="10sp"
                                android:background="@drawable/badge_light_green"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Total Amount" android:textColor="#888888" android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tv_full_total"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="₹4,995" android:textColor="#1A1A1A"
                                    android:textSize="15sp" android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Balance Later" android:textColor="#888888" android:textSize="11sp" />
                                <TextView
                                    android:id="@+id/tv_full_balance"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="₹3,996" android:textColor="#1A1A1A"
                                    android:textSize="15sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Order Summary Card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:backgroundTint="@color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order Summary"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Items sub total -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Items Sub total :"
                            android:textColor="#888888" android:textSize="13sp" />
                        <TextView android:id="@+id/tv_items_subtotal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₹198.13" android:textColor="#1A1A1A" android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Shipping -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Shipping :"
                            android:textColor="#888888" android:textSize="13sp" />
                        <TextView android:id="@+id/tv_shipping"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₹0.00" android:textColor="#1A1A1A" android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Total -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Total :"
                            android:textColor="#888888" android:textSize="13sp" />
                        <TextView android:id="@+id/tv_total"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₹198.13" android:textColor="#1A1A1A" android:textSize="13sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginBottom="10dp" />

                    <!-- Total Payable Now -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Total Payable Now :"
                            android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tv_payable_now"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₹999" android:textColor="#1A1A1A"
                            android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Balance Amount (red bg) -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="#FFF0F0"
                        android:padding="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Balance Amount"
                            android:textColor="#E41D27" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tv_balance_amount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₹3,996" android:textColor="#E41D27"
                            android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Payment Gateway placeholder ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Gateway"
                        android:textColor="#888888"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Buyer Protection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location_pin"
                    android:tint="#888888"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buyer Protection Enabled"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Place Order Button ── -->
    <Button
        android:id="@+id/btn_place_order"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Place Order &amp; Pay ₹999"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:background="@drawable/bg_button_red"
        android:layout_margin="12dp" />

</LinearLayout>