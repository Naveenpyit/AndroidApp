<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══ RED TOOLBAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#E53935"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/toolbarBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Edit your Profile"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ══ PROFILE PIC ══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iv_profile_pic"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_profile_placeholder"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg_gray"
                    android:clipToOutline="true" />

                <!-- Edit pencil badge -->
                <ImageView
                    android:id="@+id/iv_edit_profile_pic"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_edit_pencil"
                    android:background="@drawable/circle_bg_white_border"
                    android:padding="5dp"
                    android:elevation="4dp" />

            </FrameLayout>

        </FrameLayout>

        <!-- ══ FORM CARD ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Full Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name *"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edit_text"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPersonName"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:hint="Enter full name"
                    android:layout_marginBottom="16dp" />

                <!-- Mobile Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Number *"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_mobile_number"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edit_text_disabled"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="phone"
                    android:textSize="15sp"
                    android:textColor="#757575"
                    android:enabled="false"
                    android:layout_marginBottom="16dp" />

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edit_text"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textEmailAddress"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:hint="Enter email address"
                    android:layout_marginBottom="16dp" />

                <!-- Business Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Business Type *"
                    android:textSize="13sp"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_business_type"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp" />

                <!-- PAN / GST -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please provide any one"
                    android:textSize="13sp"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rgIdentity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/rbPAN"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAN Number"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:buttonTint="#E53935"
                        android:layout_marginEnd="24dp" />

                    <RadioButton
                        android:id="@+id/rbGST"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GST Number"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:buttonTint="#E53935"
                        android:checked="true" />

                </RadioGroup>

                <TextView
                    android:id="@+id/tv_pan_gst_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter GST Number"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_pan_gst"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_edit_text"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textCapCharacters"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:hint="Enter GST Number"
                    android:layout_marginBottom="16dp" />

                <!-- Shop Image -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload a shop image"
                    android:textSize="13sp"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/ll_shop_image_container"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_upload_dashed"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:id="@+id/iv_shop_image"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_upload_shop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+"
                        android:textSize="28sp"
                        android:textColor="#9E9E9E"
                        android:visibility="visible" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ══ SAVED ADDRESSES ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="Your Saved Addresses"
            android:textSize="15sp"
            android:textColor="#212121"
            android:textStyle="bold" />

        <!-- Address Card 1 (static — replace with RecyclerView for multiple) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tv_addr_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Head Office"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:textStyle="bold" />

                    <!-- Primary badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Primary"
                        android:textSize="11sp"
                        android:textColor="#1976D2"
                        android:background="@drawable/bg_badge_blue"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Edit icon -->
                    <ImageView
                        android:id="@+id/iv_edit_addr"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:layout_marginEnd="12dp" />

                    <!-- Delete icon -->
                    <ImageView
                        android:id="@+id/iv_delete_addr"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_delete" />

                </LinearLayout>

                <!-- Address line -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location_pin"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tv_addr_details"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Address will appear here"
                        android:textSize="13sp"
                        android:textColor="#757575"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- RecyclerView for multiple addresses (optional) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_addresses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone" />

        <!-- ══ SAVE BUTTON ══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_to_setup"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:text="Save Profile"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#E53935"
            app:cornerRadius="8dp" />

    </LinearLayout>

</ScrollView>