<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:background="@color/appcolor"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        card:cardCornerRadius="10dp"
        card:cardElevation="6dp"
        card:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:id="@+id/cvlogo"
                android:layout_width="wrap_content"
                android:layout_height="200dp"
                android:layout_marginTop="30dp"
                android:layout_gravity="center"
                android:src="@drawable/logo" />

            <TextView
                android:id="@+id/tvheading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTP Verification"
                android:textSize="20sp"
                android:textColor="@color/textColor"
                android:fontFamily="@font/outfitsemibold"
                android:layout_marginTop="30dp"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/txtvsubHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OTP has been sent to"
                android:textSize="14sp"
                android:textColor="@color/subheadingcolor"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:fontFamily="@font/outfitmedium"/>

            <com.chaos.view.PinView
                android:id="@+id/pinview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:cursorVisible="true"
                android:textCursorDrawable="@null"
                app:itemCount="6"
                app:itemWidth="40dp"
                app:itemHeight="40dp"
                app:itemSpacing="10dp"
                app:itemRadius="10dp"
                app:lineWidth="2dp"
                app:lineColor="@color/red"
                android:inputType="number"
                android:imeOptions="actionDone"
                style="@style/PinWidget.PinView"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/txtvotpretry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Didn’t receive OTP?"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="14sp"
                    android:fontFamily="@font/outfitmedium"/>

                <TextView
                    android:id="@+id/txtv_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Retry in"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="14sp"
                    android:fontFamily="@font/outfitmedium"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/txtv_otptimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/appcolor"
                    android:textSize="14sp"
                    android:fontFamily="@font/outfitmedium"
                    android:layout_marginStart="5dp"
                    android:visibility="gone"/>
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:text="Verify"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/appcolor"
                android:fontFamily="@font/outfitmedium"
                app:cornerRadius="8dp"/>
            <TextView
                android:id="@+id/tvAgreement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:gravity="center"
                android:layout_marginBottom="20dp"
                android:lineSpacingExtra="2dp"
                app:layout_constraintBottom_toTopOf="@id/btn_submit"
                android:fontFamily="@font/outfitregular"
                android:textColor="#8A8A8A"
                android:text="By Processing you agree to Tom Hiddle’s Privacy User Agreement &amp; Terms Conditions" />


        </LinearLayout>

    </androidx.cardview.widget.CardView>


</LinearLayout>

</LinearLayout>