<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Product Image + Wishlist Icon -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />

            <ImageView
                android:id="@+id/iv_wishlist"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:src="@drawable/ic_favorite_border"
                android:background="@drawable/circle_white_bg"
                android:padding="4dp" />

        </FrameLayout>

        <!-- Product Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Product Name -->
            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textColor="#1A1A1A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tv_product_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Price Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tv_selling_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹000"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- ✅ NO paintFlags here — set in Java via setPaintFlags() -->
                <TextView
                    android:id="@+id/tv_mrp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ₹000"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/tv_discount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 0% Off"
                    android:textColor="#E53935"
                    android:textSize="10sp"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

            <!-- MOQ -->
            <TextView
                android:id="@+id/tv_moq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MRP : ₹000 | MOQ : 0 pcs"
                android:textColor="#888888"
                android:textSize="9sp"
                android:layout_marginTop="2dp" />
            <LinearLayout
                android:id="@+id/layout_qty"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_button_red"
                android:visibility="gone"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/btn_minus"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:text="-"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tv_qty_count"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

                <TextView
                    android:id="@+id/btn_plus"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:text="+"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>
            <!-- Buy Button + Margin Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btn_add_to_cart"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:text="🛒  Add to Cart"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_button_red"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tv_margin"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="0% Margin"
                    android:textColor="#E53935"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/margin_badge_bg" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>