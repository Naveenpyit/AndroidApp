<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- ── Red Toolbar ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/red_primary"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/toolbarBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@android:color/white"
            android:padding="6dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            tools:ignore="UseAppTint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business Details"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_marginStart="48dp" />

    </RelativeLayout>

    <!-- ── Scrollable Content ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── Select Business Type ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Business type *"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!--
                NOTE: rbRetailer / rbWholesaler / rbDistributor are NOT inside
                a RadioGroup in this layout because each has a subtitle TextView
                between them. Instead, we enforce single-selection manually in
                BusinessDetailsActivity via individual OnClickListeners.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_radio_card"
                android:padding="10dp"
                android:layout_marginBottom="20dp">

                <!-- ── Retailer ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbRetailer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retailer"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:buttonTint="#E63946" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sell directly to the customers"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:layout_marginStart="32dp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="8dp" />

                <!-- ── Wholesaler ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbWholesaler"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wholesaler"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:buttonTint="#E63946" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sell in bulk quantities"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:layout_marginStart="32dp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="8dp" />

                <!-- ── Distributor ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbDistributor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distributor"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:buttonTint="#E63946" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Supply to multiple retailers"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:layout_marginStart="32dp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── GST / PAN Section ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please provide any one *"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- PAN / GST RadioGroup — proper single-selection via RadioGroup -->
            <RadioGroup
                android:id="@+id/rgIdentity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/rbPAN"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAN Number"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:buttonTint="#E63946"
                    android:layout_marginEnd="20dp" />

                <RadioButton
                    android:id="@+id/rbGST"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GST Number"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:buttonTint="#E63946"
                    android:checked="true" />
            </RadioGroup>

            <!-- GST / PAN Input -->
            <EditText
                android:id="@+id/etGSTNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter GST Number here..."
                android:padding="12dp"
                android:background="@drawable/bg_edittext"
                android:textColor="#1A1A1A"
                android:textColorHint="#999999"
                android:textSize="14sp"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="24dp" />

            <!-- ── Upload Shop Image ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upload a shop image *"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Required"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_required_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="5dp" />
            </LinearLayout>

            <!-- Upload Box -->
            <FrameLayout
                android:id="@+id/flUploadImage"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@drawable/bg_upload_dashed"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_shop_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Shop Image Preview" />

                <LinearLayout
                    android:id="@+id/ll_upload_placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_gravity="center">

                    <ImageView
                        android:id="@+id/iv_upload_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_upload"
                        android:tint="#BBBBBB"
                        android:contentDescription="Upload"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/tv_upload_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to upload shop image"
                        android:textColor="#BBBBBB"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Camera or Gallery"
                        android:textColor="#E63946"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_edit_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:background="#CC000000"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="6dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_edit"
                        android:tint="@android:color/white"
                        tools:ignore="UseAppTint"
                        android:contentDescription="Change" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  Change"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />
                </LinearLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/tv_image_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Please upload a shop image to continue"
                android:textColor="#E63946"
                android:textSize="11sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ── Save and Continue Button ── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveContinue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="Save and Continue"
        android:textSize="15sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:cornerRadius="8dp"
        app:backgroundTint="@color/red_primary" />

</LinearLayout>