<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- ── Red Toolbar ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/red_primary"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/toolbarBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@android:color/white"
            android:padding="6dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            tools:ignore="UseAppTint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business Details"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_marginStart="48dp" />

    </RelativeLayout>

    <!-- ── Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- GST / PAN number display box -->
        <TextView
            android:id="@+id/tv_gst_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GST No\n29AAACC1206D2ZB"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:padding="14dp"
            android:background="@drawable/bg_gst_box"
            android:layout_marginBottom="32dp" />

        <!-- Illustration area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Verification illustration placeholder -->
            <ImageView
                android:id="@+id/iv_verify_illustration"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@drawable/ic_gst_verify"
                android:scaleType="fitCenter"
                android:contentDescription="Verification Illustration" />

            <!-- Main message -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your details are getting verified..."
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="24dp" />

            <!-- Sub message -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Takes usually 2-4 hours"
                android:textColor="#999999"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Bottom Button ── -->
    <Button
        android:id="@+id/btn_back_to_setup"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Back to Setup Your Account"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:background="@drawable/bg_button_red"
        android:layout_margin="16dp" />

</LinearLayout>