<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background -->
    <solid android:color="@android:color/white"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#DADADA"/>

    <!-- Rounded Corners -->
    <corners android:radius="10dp"/>

    <!-- Padding inside button -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="8dp"
        android:bottom="8dp"/>
</shape>